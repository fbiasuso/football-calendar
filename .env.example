# Environment variables template
# Copy this file to .env and fill in your values

# Football API key (required — used by the configured provider, e.g. football-data.org)
VITE_FOOTBALL_API_KEY=your_api_key_here

# Football provider (optional — 'football-data' or 'api-football', defaults to football-data)
VITE_FOOTBALL_PROVIDER=football-data

# Supabase (required for Realtime, budget, force fetch)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Password para scripts locales (seed, migraciones) — opcional
VITE_SUPABASE_DB_PASSWORD=your_db_password_here
